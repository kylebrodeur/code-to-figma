{
  "name": "code-to-figma",
  "version": "0.1.0",
  "private": true,
  "description": "Monorepo for code-to-figma: Sync React components to Figma designs",
  "scripts": {
    "build": "turbo run build",
    "build:cli": "pnpm --filter @kylebrodeur/code-to-figma build",
    "build:plugin": "pnpm --filter @kylebrodeur/code-to-figma-plugin build",
    "dev:cli": "pnpm --filter @kylebrodeur/code-to-figma dev",
    "dev:plugin": "pnpm --filter @kylebrodeur/code-to-figma-plugin watch",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "turbo": "^2.0.0"
  },
  "packageManager": "pnpm@9.0.0",
  "pnpm": {
    "overrides": {
      "esbuild": ">=0.25.0"
    }
  }
}
