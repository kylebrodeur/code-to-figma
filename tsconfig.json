{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["ES2017"],
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "types": ["@figma/plugin-typings"],
    "module": "CommonJS",
    "moduleResolution": "node",
    "outDir": "./dist",
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts", "figma/**/*.js"],
  "exclude": ["node_modules", "theme", "dist"]
}
