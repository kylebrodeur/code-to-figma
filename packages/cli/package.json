{
  "name": "@kylebrodeur/code-to-figma",
  "version": "0.1.1",
  "description": "CLI tool for syncing React components to Figma designs",
  "author": "Kyle Brodeur",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kylebrodeur/code-to-figma.git",
    "directory": "packages/cli"
  },
  "bugs": "https://github.com/kylebrodeur/code-to-figma/issues",
  "homepage": "https://www.npmjs.com/package/@kylebrodeur/code-to-figma",
  "keywords": [
    "figma",
    "react",
    "design-system",
    "cli",
    "code-to-design",
    "tailwind",
    "tailwindcss",
    "tailwind-v4",
    "shadcn",
    "shadcn-ui",
    "radix-ui",
    "base-ui",
    "figma-variables",
    "component-sync",
    "design-tokens",
    "figma-plugin"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./parser": {
      "import": "./dist/parser/index.js",
      "types": "./dist/parser/index.d.ts"
    },
    "./generator": {
      "import": "./dist/generator/index.js",
      "types": "./dist/generator/index.d.ts"
    }
  },
  "bin": {
    "code-to-figma": "./dist/cli.js",
    "c2f": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && chmod +x dist/cli.js",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@babel/parser": "^7.24.0",
    "@babel/traverse": "^7.24.0",
    "@babel/types": "^7.24.0",
    "chokidar": "^3.6.0",
    "commander": "^12.0.0",
    "fast-glob": "^3.3.0",
    "picocolors": "^1.0.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.8.0",
    "@types/babel__traverse": "^7.20.0",
    "@types/node": "^20.0.0",
    "execa": "^9.6.1",
    "typescript": "^5.4.0",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
